# Optional local overrides for docker-compose.yml.
# The default compose stack works without editing this file, but copying it to
# `.env` gives you an obvious place to override ports, tokens, and log format.

# Runtime API
KL_API_PORT=8080
KL_LISTEN_ADDR=:8080

# Control API
KL_CONTROL_PORT=8090
KL_CONTROL_TOKEN=local-control-token
KL_CONTROL_PUBLIC_API=

# Postgres ports
KL_META_PORT=5432
KL_SHARED_PORT=5433
KL_PREMIUM_PORT=5434

# Logging
KL_LOG_LEVEL=info
KL_LOG_FORMAT=text

# Init / transport
KL_INIT_MODE=prod
KL_PROD_TLS_REQUIRED=false

# Build tags (leave empty for OSS/self-hosted build)
KL_GO_TAGS=
